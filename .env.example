# Prisma/PostgreSQL database connection
# Example local database URL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/campusbridge
# Example Supabase URL:
# DATABASE_URL=postgresql://postgres:password@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Clerk authentication
NEXT_PUBLIC_CLERK_FRONTEND_API=your-clerk-frontend-api
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key

# Supabase realtime connection (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
